# Microsoft Entra External ID (gebruikt in Fase 0 stap 5)
VITE_ENTRA_TENANT_NAME=
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_AUTHORITY_URL=
VITE_ENTRA_USER_FLOW=

# RAM API (gebruikt in Fase 0 stap 6)
# ACC (acceptance) voor Fase-0 development; PRD wordt later geconfigureerd.
VITE_RAM_API_BASE_URL=https://ram-api-es-acc.azurewebsites.net

# RAM API v2 — tijdelijke API-key auth (X-Api-Key header). NOOIT committen in
# .env.local. Kan ook via Settings -> API Configuration (localStorage) gezet worden.
VITE_RAM_API_KEY=

# Seasonal Planner Flask API (Sprint 1+)
# dev: http://localhost:5050 — prod: https://ram-seasonal-api.azurewebsites.net
VITE_SEASONAL_API_BASE_URL=http://localhost:5050
